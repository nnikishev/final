.env.test.local
.env.production.local

# отчёты о покрытии тестов / метрики
coverage/
*.lcov

# файлы, создаваемые генераторами статики (Next.js, Gatsby и др.)
.next/
out/
!.next/cache/

# === Python (бэкенд) ===
# виртуальное окружение
venv/
env/
ENV/
.venv
.env.backend
.python-version

# компилированные файлы
__pycache__/
*.py[cod]
*$py.class
*.so

# распределённые пакеты
/PKG-INFO
*.egg-info/
*.egg
.eggs/
dist/
build/
develop-eggs/
downloads/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/

# тесты и coverage
.coverage
.coverage.*
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
